# Optional — without these, the app serves seeded demo data (12 Bandra dentists)
# Get from https://apify.com (free tier covers ~100 leads/month)
APIFY_TOKEN=
APIFY_ACTOR=compass~crawler-google-places

# Get from https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_KEY=

# Firebase Web app config. These are public browser values from Firebase Console.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Firebase Admin SDK for server-side token verification + Firestore quota writes.
# Prefer FIREBASE_SERVICE_ACCOUNT_KEY as a base64-encoded service account JSON.
FIREBASE_SERVICE_ACCOUNT_KEY=
# Or use split credentials instead:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Quota + rate limit defaults.
FREE_LEAD_LIMIT=15
SCRAPE_RATE_LIMIT_REQUESTS=5
SCRAPE_RATE_LIMIT_WINDOW_SECONDS=60
